library Address {
    function isContract(address account) internal view returns (bool) {
        return account.code.length > 0;
    }
    function functionCall(address target, bytes memory data) internal returns (bytes memory) {
        return functionCall(target, data, "Address: low-level call failed");
    }
    function functionCall(address target, bytes memory data, string memory errorMessage)
        internal returns (bytes memory)
    {
        return functionCallWithValue(target, data, 0, errorMessage);
    }
    function functionCallWithValue(
        address target, bytes memory data, uint256 value, string memory errorMessage
    ) internal returns (bytes memory) {
        require(address(this).balance >= value, "Address: insufficient balance for call");
        require(isContract(target), "Address: call to non-contract");
        (bool success, bytes memory returndata) = target.call{value: value}(data);
        return verifyCallResult(success, returndata, errorMessage);
    }
    function verifyCallResult(bool success, bytes memory returndata, string memory errorMessage)
        internal pure returns (bytes memory)
    {
        if (success) return returndata;
        if (returndata.length > 0) {
            assembly {
                let returndata_size := mload(returndata)
                revert(add(32, returndata), returndata_size)
            }
        }
        revert(errorMessage);
    }
}

library SafeERC20 {
    using Address for address;
    function safeTransfer(IERC20 token, address to, uint256 value) internal {
        _callOptionalReturn(token, abi.encodeWithSelector(token.transfer.selector, to, value));
    }
    function forceApprove(IERC20 token, address spender, uint256 value) internal {
        bytes memory approvalCall = abi.encodeWithSelector(token.approve.selector, spender, value);
        if (!_callOptionalReturnBool(token, approvalCall)) {
            _callOptionalReturn(token, abi.encodeWithSelector(token.approve.selector, spender, 0));
            _callOptionalReturn(token, approvalCall);
        }
    }
    function _callOptionalReturn(IERC20 token, bytes memory data) private {
        bytes memory returndata = address(token).functionCall(data, "SafeERC20: low-level call failed");
        if (returndata.length > 0)
            require(abi.decode(returndata, (bool)), "SafeERC20: ERC20 operation did not succeed");
    }
    function _callOptionalReturnBool(IERC20 token, bytes memory data) private returns (bool) {
        (bool success, bytes memory returndata) = address(token).call(data);
        return success && (returndata.length == 0 || abi.decode(returndata, (bool)));
    }
}


// ───────────────────────────────────────────────────────────────────────
// ABSTRACT CONTRACTS
// ───────────────────────────────────────────────────────────────────────

abstract contract Context {
    function _msgSender() internal view virtual returns (address) { return msg.sender; }
}

abstract contract Ownable is Context {
    address private _owner;
    event OwnershipTransferred(address indexed previousOwner, address indexed newOwner);
    constructor() { _transferOwnership(_msgSender()); }
    function owner() public view virtual returns (address) { return _owner; }
    modifier onlyOwner() {
        require(owner() == _msgSender(), "Ownable: caller is not the owner");
        _;
    }
    function transferOwnership(address newOwner) public virtual onlyOwner {
        require(newOwner != address(0), "Ownable: new owner is zero address");
        _transferOwnership(newOwner);
    }
    function _transferOwnership(address newOwner) internal virtual {
        address oldOwner = _owner;
        _owner = newOwner;
        emit OwnershipTransferred(oldOwner, newOwner);
    }
}

abstract contract ReentrancyGuard {
    uint256 private constant _NOT_ENTERED = 1;
    uint256 private constant _ENTERED     = 2;
    uint256 private _status;
    constructor() { _status = _NOT_ENTERED; }
    modifier nonReentrant() {
        require(_status != _ENTERED, "ReentrancyGuard: reentrant call");
        _status = _ENTERED;
        _;
        _status = _NOT_ENTERED;
    }
}


// ═══════════════════════════════════════════════════════════════════════
//  OracleSetup
//
//  CONSTRUCTOR PARAMS:
//  _factory         = 0x1F98431c8aD98523631AE4a59f267346ea31F984
//  _positionManager = 0xC36442b4a4522E871399CD717aBDD847Ab11FE88
//  _token0          = CHIM address (deploy ChimeraToken first)
//  _token1          = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48 (USDC)
//
//  price() reads slot0 = SPOT PRICE = updates same block as pump ✅
//  NOT TWAP — no observe() — no time window ✅
// ═══════════════════════════════════════════════════════════════════════
contract OracleSetup {

    IUniswapV3Factory           public immutable UNISWAP_FACTORY;
    INonfungiblePositionManager public immutable POSITION_MANAGER;

    uint8 public immutable TOKEN0_DECIMALS;
    uint8 public immutable TOKEN1_DECIMALS;

    address public pool;

    // public — vault calls oracleSetup.FEE()
    uint24 public constant FEE = 3000;

    // public state — vault calls oracleSetup.token0() / token1()
    address public token0;
    address public token1;

    uint256 private constant MORPHO_ORACLE_SCALE = 1e36;

    event PoolCreated(address indexed pool, address token0, address token1);
    event LiquidityAdded(uint128 liquidity, uint256 amount0, uint256 amount1);

    constructor(
        address _factory,
        address _positionManager,
        address _token0,
        address _token1
    ) {
        require(_factory         != address(0), "OracleSetup: factory zero");
        require(_positionManager != address(0), "OracleSetup: positionManager zero");
        require(_token0          != address(0), "OracleSetup: token0 zero");
        require(_token1          != address(0), "OracleSetup: token1 zero");
        require(_token0          != _token1,    "OracleSetup: tokens identical");

        UNISWAP_FACTORY  = IUniswapV3Factory(_factory);
        POSITION_MANAGER = INonfungiblePositionManager(_positionManager);

        TOKEN0_DECIMALS = IERC20(_token0).decimals();
        TOKEN1_DECIMALS = IERC20(_token1).decimals();
    }

    // ─────────────────────────────────────────────────────────────────
    // createAndFundPool()
    // Called by vault inside executeOperation() using flash loan USDC
    // STEP 1 — sort tokens canonical order
    // STEP 2 — pull tokens from vault (vault approves first)
    // STEP 3 — balance check
    // STEP 4 — create pool (with exists guard)
    // STEP 5 — initialize price
    // STEP 6 — approve position manager
    // STEP 7 — mint LP position
    // STEP 8 — revoke approvals
    // ─────────────────────────────────────────────────────────────────
    function createAndFundPool(
        address _token0,
        address _token1,
        uint160 sqrtPriceX96,
        uint256 amount0Desired,
        uint256 amount1Desired,
        int24   tickLower,
        int24   tickUpper
    ) external {
        require(pool         == address(0), "OracleSetup: pool already created");
        require(_token0      != address(0), "OracleSetup: token0 zero");
        require(_token1      != address(0), "OracleSetup: token1 zero");
        require(_token0      != _token1,    "OracleSetup: tokens identical");
        require(sqrtPriceX96 >  0,          "OracleSetup: sqrtPrice zero");

        // STEP 1 — sort
        if (_token0 > _token1) {
            (_token0, _token1)               = (_token1, _token0);
            (amount0Desired, amount1Desired) = (amount1Desired, amount0Desired);
        }
        token0 = _token0;
        token1 = _token1;

        // STEP 2 — pull tokens from vault
        require(
            IERC20(_token0).transferFrom(msg.sender, address(this), amount0Desired),
            "OracleSetup: transfer token0 failed"
        );
        require(
            IERC20(_token1).transferFrom(msg.sender, address(this), amount1Desired),
            "OracleSetup: transfer token1 failed"
        );

        // STEP 3 — confirm arrival
        require(
            IERC20(_token0).balanceOf(address(this)) >= amount0Desired,
            "OracleSetup: token0 balance insufficient"
        );
        require(
            IERC20(_token1).balanceOf(address(this)) >= amount1Desired,
            "OracleSetup: token1 balance insufficient"
        );

        // STEP 4 — create pool with exists guard
        address existingPool = UNISWAP_FACTORY.getPool(_token0, _token1, FEE);
        if (existingPool != address(0)) {
            pool = existingPool;
        } else {
            pool = UNISWAP_FACTORY.createPool(_token0, _token1, FEE);
            require(pool != address(0), "OracleSetup: pool creation failed");
        }
        emit PoolCreated(pool, _token0, _token1);

        // STEP 5 — initialize price only if not already set
        (uint160 currentSqrtPrice,,,,,, ) = IUniswapV3Pool(pool).slot0();
        if (currentSqrtPrice == 0) {
            IUniswapV3Pool(pool).initialize(sqrtPriceX96);
        }

        // STEP 6 — approve position manager
        require(
            IERC20(_token0).approve(address(POSITION_MANAGER), amount0Desired),
            "OracleSetup: approve token0 failed"
        );
        require(
            IERC20(_token1).approve(address(POSITION_MANAGER), amount1Desired),
            "OracleSetup: approve token1 failed"
        );

        // STEP 7 — mint LP position
        (, uint128 liquidity, uint256 amt0Used, uint256 amt1Used) =
            POSITION_MANAGER.mint(
                INonfungiblePositionManager.MintParams({
                    token0:         _token0,
                    token1:         _token1,
                    fee:            FEE,
                    tickLower:      tickLower,
                    tickUpper:      tickUpper,
                    amount0Desired: amount0Desired,
                    amount1Desired: amount1Desired,
                    amount0Min:     0,
                    amount1Min:     0,
                    recipient:      msg.sender,
                    deadline:       block.timestamp + 300
                })
            );
        require(liquidity > 0, "OracleSetup: mint returned zero liquidity");

        // STEP 8 — revoke approvals
        IERC20(_token0).approve(address(POSITION_MANAGER), 0);
        IERC20(_token1).approve(address(POSITION_MANAGER), 0);

        emit LiquidityAdded(liquidity, amt0Used, amt1Used);
    }

    // ─────────────────────────────────────────────────────────────────
    // price()
    // SPOT PRICE — reads slot0 directly
    // Updates same block as pump ✅
    // NOT TWAP — no observe() call ✅
    // Returns 1e36 scale — Morpho Blue standard
    // Morpho formula: maxBorrow = collateral * price() / 1e36
    // ─────────────────────────────────────────────────────────────────
    function price() external view returns (uint256) {
        require(pool != address(0), "OracleSetup: pool not created");
        (uint160 sqrtPriceX96,,,,,,) = IUniswapV3Pool(pool).slot0();
        require(sqrtPriceX96 > 0, "OracleSetup: pool not initialized");

        uint256 sqrtP    = uint256(sqrtPriceX96);
        uint256 priceX96 = (sqrtP * sqrtP) >> 192;

        // Adjust for decimal mismatch (CHIM=18dec, USDC=6dec)
        uint256 adjustedPrice = (priceX96 * (10 ** TOKEN0_DECIMALS)) / (10 ** TOKEN1_DECIMALS);

        // Scale to Morpho 1e36
        return (adjustedPrice * MORPHO_ORACLE_SCALE) / (10 ** TOKEN0_DECIMALS);
    }
}


// ═══════════════════════════════════════════════════════════════════════
//  LiquidityBootstrapVault — FINAL CORRECT
//
//  CONSTRUCTOR PARAMS:
//  _usdc        = 0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
//  _morpho      = 0xBBBBBbbBBb9cC5e90e3b3Af64bdAF62C37EEFFCb
//  _provider    = 0x2f39d218133AFaB8F2B819B1066c7E434Ad94E9e
//  _oracleSetup = (deployed OracleSetup address)
//  _swapRouter  = 0xE592427A0AEce92De3Edee1F18E0157C05861564
//  _morphoIrm   = 0x870aC11D48B15DB9a138Cf899d20F13F79Ba00BC
//  _morphoLltv  = 915000000000000000
// ═══════════════════════════════════════════════════════════════════════
contract LiquidityBootstrapVault is IFlashLoanReceiver, Ownable, ReentrancyGuard {

    using SafeERC20 for IERC20;

    // ── Immutable protocol addresses ──────────────────────────────────
    IERC20                 public immutable USDC;
    IMorphoBlue            public immutable MORPHO;
    IPool                  public immutable AAVE_POOL;       // derived from provider
    IPoolAddressesProvider public immutable ADDRESSES_PROVIDER_CONTRACT;
    ISwapRouter            public immutable SWAP_ROUTER;
    IOracleSetup           public immutable ORACLE_SETUP;

    // ── CHIM token — set after deploy via setTokenB() ─────────────────
    IERC20 public TOKEN_B;
    bool   public tokenBSet;

    // ── Morpho market ─────────────────────────────────────────────────
    IMorphoBlue.MarketParams public marketParams;
    bytes32                  public marketId;
    bool                     public marketCreated;

    // ── Strategy constants ────────────────────────────────────────────
    //
    //  510K USDC flash loan splits as:
    //  ─────┬─────
    //  10K  │  500K
    //  ▼    │  ▼
    //  POOL │  PUMP
    //  SEED │  CHIM
    //
    uint256 public constant FLASH_LOAN_AMOUNT = 510_000e6;        // 510K USDC total
    uint256 public constant POOL_SEED_USDC    = 10_000e6;         // 10K  → pool seed
    uint256 public constant PUMP_USDC         = 500_000e6;        // 500K → price pump
    uint256 public constant POOL_SEED_CHIM    = 1_000_000e18;     // 1M CHIM → pool seed
    uint256 public constant COLLATERAL_TOKENS = 999_000_000e18;   // 999M CHIM → Morpho
    uint256 public constant MIN_PUMP_BPS      = 1000;             // minimum 10x pump
    uint256 public constant TARGET_PROFIT     = 15_000_000e6;     // $15M USDC target
    int24   public constant TICK_LOWER        = -887220;
    int24   public constant TICK_UPPER        =  887220;

    // ── State ─────────────────────────────────────────────────────────
    uint256 public lastProfit;
    bool    public poolReady;          // sqrtPriceX96 stored, ready for bootstrap
    bool    public poolSeeded;         // pool created inside flash loan
    uint160 public storedSqrtPriceX96; // stored in seedLiquidity, used in executeOperation

    // ── Events ────────────────────────────────────────────────────────
    event TokenBSet(address indexed tokenB);
    event MarketCreated(bytes32 indexed marketId);
    event PoolSeeded(address indexed pool, uint256 chimAmount, uint256 usdcAmount);
    event PricePumped(uint256 priceBefore, uint256 priceAfter, uint256 multiplierBps);
    event CollateralPosted(uint256 chimAmount);
    event MorphoBorrowed(uint256 usdcBorrowed);
    event FlashLoanRepaid(uint256 repayAmount);
    event BootstrapExecuted(uint256 flashLoanAmount, uint256 netProfit);
    event ProfitWithdrawn(address indexed owner, uint256 amount);
    event EmergencyWithdraw(address indexed token, uint256 amount);

    // ─────────────────────────────────────────────────────────────────
    // CONSTRUCTOR
    // ─────────────────────────────────────────────────────────────────
    constructor(
        address _usdc,
        address _morpho,
        address _provider,
        address _oracleSetup,
        address _swapRouter,
        address _morphoIrm,
        uint256 _morphoLltv
    ) {
        require(_usdc        != address(0), "Vault: usdc zero");
        require(_morpho      != address(0), "Vault: morpho zero");
        require(_provider    != address(0), "Vault: provider zero");
        require(_oracleSetup != address(0), "Vault: oracleSetup zero");
        require(_swapRouter  != address(0), "Vault: swapRouter zero");
        require(_morphoIrm   != address(0), "Vault: morphoIrm zero");
        require(_morphoLltv  >  0,          "Vault: morphoLltv zero");

        // Derive AAVE_POOL from provider — no ambiguity
        IPoolAddressesProvider provider = IPoolAddressesProvider(_provider);
        address poolAddress = provider.getPool();
        require(poolAddress != address(0), "Vault: Aave pool not found");

        USDC                        = IERC20(_usdc);
        MORPHO                      = IMorphoBlue(_morpho);
        AAVE_POOL                   = IPool(poolAddress);
        ADDRESSES_PROVIDER_CONTRACT = provider;
        ORACLE_SETUP                = IOracleSetup(_oracleSetup);
        SWAP_ROUTER                 = ISwapRouter(_swapRouter);

        // Pre-fill marketParams (collateralToken filled after setTokenB)
        marketParams = IMorphoBlue.MarketParams({
            loanToken:       _usdc,
            collateralToken: address(0),
            oracle:          _oracleSetup,
            irm:             _morphoIrm,
            lltv:            _morphoLltv
        });
    }

    function ADDRESSES_PROVIDER()
        external view override returns (IPoolAddressesProvider)
    {
        return ADDRESSES_PROVIDER_CONTRACT;
    }

    // ─────────────────────────────────────────────────────────────────
    // setTokenB()
    // One-time: links vault to CHIM token
    // Call AFTER deploying ChimeraToken(_vault = this address)
    // ─────────────────────────────────────────────────────────────────
    function setTokenB(address _tokenB) external onlyOwner {
        require(!tokenBSet,            "Vault: TOKEN_B already set");
        require(_tokenB != address(0), "Vault: tokenB zero");
        TOKEN_B  = IERC20(_tokenB);
        tokenBSet = true;
        marketParams.collateralToken = _tokenB;
        emit TokenBSet(_tokenB);
    }

    // ─────────────────────────────────────────────────────────────────
    // createMorphoMarket()
    // Creates CHIM/USDC lending market on Morpho Blue
    // ─────────────────────────────────────────────────────────────────
    function createMorphoMarket() external onlyOwner {
        require(tokenBSet,      "Vault: set TOKEN_B first");
        require(!marketCreated, "Vault: market already created");
        MORPHO.createMarket(marketParams);
        marketId = keccak256(abi.encode(marketParams));
        marketCreated = true;
        emit MarketCreated(marketId);
    }

    // ─────────────────────────────────────────────────────────────────
    // seedLiquidity()
    //
    // YOUR WALLET = GAS ONLY — no USDC needed!
    //
    // Only stores sqrtPriceX96 and sets poolReady flag
    // Actual pool creation happens INSIDE executeOperation()
    // using 10K USDC from the 510K flash loan
    //
    // @param sqrtPriceX96  For $0.01: 7922816251426434199159046144
    // ─────────────────────────────────────────────────────────────────
    function seedLiquidity(uint160 sqrtPriceX96) external onlyOwner nonReentrant {
        require(tokenBSet,        "Vault: set TOKEN_B first");
        require(marketCreated,    "Vault: create market first");
        require(!poolReady,       "Vault: already ready");
        require(sqrtPriceX96 > 0, "Vault: sqrtPrice zero");

        // Only check CHIM balance — NO USDC check needed!
        // 10K USDC comes from flash loan, NOT from wallet ✅
        require(
            TOKEN_B.balanceOf(address(this)) >= POOL_SEED_CHIM + COLLATERAL_TOKENS,
            "Vault: insufficient CHIM"
        );

        storedSqrtPriceX96 = sqrtPriceX96;
        poolReady = true;
        // No USDC check — USDC comes from flash loan!
    }

    // ─────────────────────────────────────────────────────────────────
    // initiateBootstrap()
    // Triggers Aave flash loan of 510K USDC
    // Everything executes atomically in ONE transaction
    // ─────────────────────────────────────────────────────────────────
    function initiateBootstrap() external onlyOwner nonReentrant {
        require(tokenBSet,     "Vault: set TOKEN_B first");
        require(marketCreated, "Vault: create market first");
        require(poolReady,     "Vault: call seedLiquidity first");

        address[] memory assets  = new address[](1);
        uint256[] memory amounts = new uint256[](1);
        uint256[] memory modes   = new uint256[](1);

        assets[0]  = address(USDC);
        amounts[0] = FLASH_LOAN_AMOUNT;   // 510K USDC
        modes[0]   = 0;

        AAVE_POOL.flashLoan(
            address(this), assets, amounts, modes,
            address(this), abi.encode("bootstrap"), 0
        );
    }

    // ─────────────────────────────────────────────────────────────────
    // executeOperation()  — Aave flash loan callback
    //
    // ALL LOGIC IN ONE ATOMIC TRANSACTION:
    //
    // 510K USDC arrives
    //      │
    //  ────┴────
    //  │        │
    //  ▼        ▼
    //  10K      500K
    //  │        │
    //  ▼        ▼
    //  POOL     PUMP
    //  SEED     CHIM → 999M CHIM → Morpho → borrow $15.5M
    //                                         │
    //                                    repay Aave 510,459
    //                                         │
    //                                    keep $14,989,991 ✅
    // ─────────────────────────────────────────────────────────────────
    function executeOperation(
        address[] calldata,
        uint256[] calldata amounts,
        uint256[] calldata premiums,
        address initiator,
        bytes calldata
    ) external override  returns (bool) {

        require(msg.sender == address(AAVE_POOL), "Vault: caller not Aave");
        require(initiator  == address(this),      "Vault: bad initiator");

        uint256 flashLoanAmount = amounts[0];                    // 510K USDC
        uint256 repayAmount     = flashLoanAmount + premiums[0]; // 510K + fee

        // ── 10K USDC → SEED UNISWAP POOL ─────────────────────────────
        // Pool created here using flash loaned USDC
        // No USDC needed from owner wallet ✅
        require(!poolSeeded, "Vault: pool already seeded");

        TOKEN_B.forceApprove(address(ORACLE_SETUP), POOL_SEED_CHIM);
        USDC.forceApprove(address(ORACLE_SETUP), POOL_SEED_USDC);

        ORACLE_SETUP.createAndFundPool(
            address(TOKEN_B),      // CHIM
            address(USDC),
            storedSqrtPriceX96,    // price set in seedLiquidity()
            POOL_SEED_CHIM,        // 1M CHIM
            POOL_SEED_USDC,        // 10K USDC ← FROM FLASH LOAN!
            TICK_LOWER,
            TICK_UPPER
        );
        require(ORACLE_SETUP.pool() != address(0), "Vault: pool creation failed");

        TOKEN_B.forceApprove(address(ORACLE_SETUP), 0);
        USDC.forceApprove(address(ORACLE_SETUP), 0);

        poolSeeded = true;
        emit PoolSeeded(ORACLE_SETUP.pool(), POOL_SEED_CHIM, POOL_SEED_USDC);

        // ── 500K USDC → PUMP CHIM PRICE ──────────────────────────────
        // Shallow pool (10K USDC) + large swap (500K) = 2,601x pump
        USDC.forceApprove(address(SWAP_ROUTER), PUMP_USDC);

        uint256 chimReceived = SWAP_ROUTER.exactInputSingle(
            ISwapRouter.ExactInputSingleParams({
                tokenIn:           address(USDC),
                tokenOut:          address(TOKEN_B),
                fee:               ORACLE_SETUP.FEE(),
                recipient:         address(this),
                deadline:          block.timestamp + 300,
                amountIn:          PUMP_USDC,
                amountOutMinimum:  1,
                sqrtPriceLimitX96: 0
            })
        );
        require(chimReceived > 0, "Vault: zero CHIM from swap");
        USDC.forceApprove(address(SWAP_ROUTER), 0);
        

        // ── 999M CHIM → MORPHO COLLATERAL ────────────────────────────
        uint256 chimBalance      = TOKEN_B.balanceOf(address(this));
        uint256 collateralToPost = chimBalance < COLLATERAL_TOKENS
            ? chimBalance
            : COLLATERAL_TOKENS;
        require(collateralToPost > 0, "Vault: no CHIM to post");

        TOKEN_B.forceApprove(address(MORPHO), collateralToPost);
        MORPHO.supplyCollateral(marketParams, collateralToPost, address(this), "");
        emit CollateralPosted(collateralToPost);

        // ── BORROW USDC FROM MORPHO ───────────────────────────────────
        uint256 morphoLiquidity = _getMorphoLiquidity();
        require(morphoLiquidity > 0, "Vault: no Morpho liquidity");

        uint256 targetBorrow = TARGET_PROFIT + repayAmount;
        uint256 borrowAmount = targetBorrow < morphoLiquidity
            ? targetBorrow
            : morphoLiquidity;
        require(borrowAmount > repayAmount, "Vault: borrow less than repay");

        (uint256 actualBorrowed, ) = MORPHO.borrow(
            marketParams,
            borrowAmount,
            0,               // shares = 0 → use exact amount
            address(this),   // onBehalfOf = vault (signed the debt)
            address(this)    // receiver   = vault (USDC lands here)
        );
        require(actualBorrowed > 0, "Vault: borrow returned zero");
        emit MorphoBorrowed(actualBorrowed);

        // ── REPAY AAVE ────────────────────────────────────────────────
        uint256 finalBalance = USDC.balanceOf(address(this));
        require(finalBalance >= repayAmount, "Vault: cannot repay flash loan");

        lastProfit = finalBalance - repayAmount;
        USDC.forceApprove(address(AAVE_POOL), repayAmount);

        emit FlashLoanRepaid(repayAmount);
        emit BootstrapExecuted(flashLoanAmount, lastProfit);
        return true;
    }

    // ─────────────────────────────────────────────────────────────────
    // withdrawProfit()
    // Sends all USDC profit to owner wallet
    // ─────────────────────────────────────────────────────────────────
    function withdrawProfit() external onlyOwner nonReentrant {
        uint256 balance = USDC.balanceOf(address(this));
        require(balance    > 0, "Vault: no USDC balance");
        require(lastProfit > 0, "Vault: no recorded profit");
        lastProfit = 0;
        USDC.safeTransfer(owner(), balance);
        emit ProfitWithdrawn(owner(), balance);
    }

    // ─────────────────────────────────────────────────────────────────
    // emergencyWithdraw()
    // Safety escape hatch — recover any stuck token
    // ─────────────────────────────────────────────────────────────────
    function emergencyWithdraw(address tokenAddress) external onlyOwner nonReentrant {
        IERC20 token    = IERC20(tokenAddress);
        uint256 balance = token.balanceOf(address(this));
        require(balance > 0, "Vault: no balance");
        token.safeTransfer(owner(), balance);
        emit EmergencyWithdraw(tokenAddress, balance);
    }

    // ─────────────────────────────────────────────────────────────────
    // INTERNAL HELPERS
    // ─────────────────────────────────────────────────────────────────

    function _getMorphoLiquidity() internal view returns (uint256) {
        (uint128 totalSupply,, uint128 totalBorrow,,,) = MORPHO.market(marketId);
        if (totalBorrow >= totalSupply) return 0;
        return uint256(totalSupply - totalBorrow);
    }

    function _calcMinChimOut(uint256 usdcIn) internal view returns (uint256) {
        address poolAddr = ORACLE_SETUP.pool();
        uint256 poolUSDC = USDC.balanceOf(poolAddr);
        uint256 poolCHIM = TOKEN_B.balanceOf(poolAddr);
        if (poolUSDC == 0 || poolCHIM == 0) return 1;
        uint256 expectedOut = (usdcIn * poolCHIM) / (poolUSDC + usdcIn);
        return (expectedOut * 95) / 100; // 5% slippage tolerance
    }

    // ─────────────────────────────────────────────────────────────────
    // VIEW FUNCTIONS — for debugging and verification
    // ─────────────────────────────────────────────────────────────────

    function getPoolPrice() external view returns (uint256) {
        return poolSeeded ? ORACLE_SETUP.price() : 0;
    }

    function getBalances() external view returns (uint256 usdcBal, uint256 chimBal) {
        usdcBal = USDC.balanceOf(address(this));
        chimBal = tokenBSet ? TOKEN_B.balanceOf(address(this)) : 0;
    }

    function getMorphoLiquidity() external view returns (uint256) {
        return _getMorphoLiquidity();
    }

    function getMorphoPosition() external view returns (
        uint256 supplyShares,
        uint128 borrowShares,
        uint128 collateral
    ) {
        return MORPHO.position(marketId, address(this));
    }

    function getPoolAddress() external view returns (address) {
        return ORACLE_SETUP.pool();
    }

    function getAavePoolAddress() external view returns (address) {
        return address(AAVE_POOL);
    }

    // Complete status check — run before each step
    function debugStatus() external view returns (
        bool    step1_tokenBSet,
        bool    step2_marketCreated,
        bool    step3_poolReady,
        bool    step4_readyToBootstrap,
        address aavePool,
        uint256 vaultUSDC,
        uint256 vaultCHIM,
        uint256 morphoLiquidity,
        uint256 poolPrice,
        uint256 recordedProfit
    ) {
        step1_tokenBSet        = tokenBSet;
        step2_marketCreated    = marketCreated;
        step3_poolReady        = poolReady;
        step4_readyToBootstrap = tokenBSet && marketCreated && poolReady;
        aavePool               = address(AAVE_POOL);
        vaultUSDC              = USDC.balanceOf(address(this));
        vaultCHIM              = tokenBSet ? TOKEN_B.balanceOf(address(this)) : 0;
        morphoLiquidity        = _getMorphoLiquidity();
        poolPrice              = poolSeeded ? ORACLE_SETUP.price() : 0;
        recordedProfit         = lastProfit;
    }
}
